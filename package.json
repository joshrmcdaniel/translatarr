    "clients:regen:ts": "clients/typescript/scripts/regenerate.sh",
    "clients:regen:rust": "clients/rust/scripts/regenerate.sh",
    "clients:regen": "bun run clients:regen:python && bun run clients:regen:ts && bun run clients:regen:rust"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "better-sqlite3": "^12.10.0",
