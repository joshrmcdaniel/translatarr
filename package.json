    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "playwright": "^1.60.0",
    "swagger-ui-dist": "5.32.8",
    "typescript": "^5.8.3"
  }
