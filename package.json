{
  "name": "translatarr",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run swagger:ui && next dev",
    "build": "bun run swagger:ui && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "swagger:ui": "bun scripts/copy-swagger-ui.mjs",
